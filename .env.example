# Copy to .env for local development (not committed).
ENV=local
LOG_LEVEL=info

# API
API_ADDR=:8080
WEBHOOK_ADDR=:8081

# Storage: false = Postgres (recommended with docker compose)
USE_MEMORY_STORE=false
DATABASE_URL=postgres://dashfetchr:dashfetchr@localhost:5432/dashfetchr?sslmode=disable
DB_MAX_CONNS=10

# Dispatcher worker
DISPATCH_POLL_INTERVAL=30s
DISPATCH_BATCH_SIZE=20

# Bolt (optional — dispatch calls real API when set)
BOLT_API_KEY=
BOLT_WEBHOOK_SECRET=local-dev-secret
BOLT_SANDBOX=true
BOLT_BASE_URL=https://node.bolt.eu
BOLT_SERVICE_AREA=bucharest
